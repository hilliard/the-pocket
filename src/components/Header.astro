---
import { verifySession } from '../server/auth';
export interface Props {
  artistSlug?: string;
  artistName?: string;
}

const { artistSlug, artistName } = Astro.props;

// Determine if we are in a specific artist's store context or the global portal
const isArtistContext = !!artistSlug;

// Read Cart State for initial SSR render
const cartCookie = Astro.cookies.get('pocket_cart')?.value;
let cartCount = 0;
if (cartCookie) {
  try {
    const parsed = JSON.parse(cartCookie);
    if (Array.isArray(parsed)) cartCount = parsed.length;
  } catch (e) {}
}
const sessionCookieHeader = Astro.cookies.get('pocket_session')?.value;
let currentUsername = null;
if (sessionCookieHeader) {
  const s = verifySession(sessionCookieHeader);
  if (s) currentUsername = s.username;
}
---

<header class="border-b border-mono-800 bg-mono-900/50 backdrop-blur-md sticky top-0 z-50 transition-colors">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 flex justify-between items-center">
    
    <!-- Left side: Brand / Navigation -->
    <div class="flex items-center gap-4">
      <a href="/clients/public" class="font-bold tracking-tight flex items-center gap-2 group">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-tr from-accent to-mono-50 flex items-center justify-center transition-transform group-hover:scale-105">
          <span class="text-mono-950 text-sm font-black">P</span>
        </div>
        <span class="hidden sm:inline-block">The Pocket</span>
      </a>
      
      {isArtistContext && (
        <>
          <span class="text-mono-600 hidden sm:inline">/</span>
          <a href={`/clients/artists/${artistSlug}/public`} class="text-sm font-semibold text-mono-300 hover:text-accent transition-colors truncate max-w-[150px] sm:max-w-xs">
            {artistName}
          </a>
        </>
      )}
    </div>

    <!-- Right side: Cart & Mobile Menu -->
    <div class="flex items-center gap-4">
      {/* Hotwire Cart Counter */}
      <turbo-frame id="cart_counter">
        <a href="/cart" data-turbo-frame="_top" class="flex items-center gap-2 hover:text-accent transition-colors p-2 -mr-2 sm:p-0 sm:mr-0 relative group">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
          <!-- Default empty state, server API will turbo-stream the active state -->
          <span class="absolute -top-1 -right-1 sm:static sm:font-medium bg-mono-800 sm:px-2 py-0.5 rounded-full text-[10px] sm:text-xs w-4 h-4 sm:w-auto sm:h-auto flex items-center justify-center">
            {cartCount}
          </span>
        </a>
      </turbo-frame>
      
      {/* Mobile Hamburger Menu (Stimulus controller would go here in production) */}
      <button class="sm:hidden text-mono-300 hover:text-mono-50 p-2" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
      
      {/* Desktop Links */}
      <nav class="hidden sm:flex items-center gap-6 text-sm font-medium text-mono-400">
        
        {/* Theme Toggle Button */}
        <button type="button" id="theme-toggle" class="hover:text-accent transition-colors" aria-label="Toggle Dark Mode">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 dark-icon" viewBox="0 0 20 20" fill="currentColor">
            <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
          </svg>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 light-icon hidden" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4.22 4.22a1 1 0 011.415 0l.884.884a1 1 0 01-1.414 1.415l-.884-.884a1 1 0 010-1.415zM1 10a1 1 0 110-2h1a1 1 0 110 2H1zm15 0a1 1 0 110-2h1a1 1 0 110 2h-1zM4.22 15.78a1 1 0 010-1.415l.884-.884a1 1 0 011.414 1.415l-.884.884a1 1 0 01-1.415 0zm11.56 0a1 1 0 01-1.415 0l-.884-.884a1 1 0 011.414-1.415l.884.884a1 1 0 010 1.415zM10 16a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1z" clip-rule="evenodd" />
          </svg>
        </button>

        <a href="/store" class="hover:text-mono-50 transition-colors">Store</a>
        {currentUsername ? (
          <div class="flex items-center gap-6">
            <span class="text-mono-300">Welcome: <span class="font-bold text-mono-50">{currentUsername}</span></span>
            <a href="/dashboard" class="hover:text-mono-50 transition-colors font-bold text-accent">Dashboard</a>
            <form method="POST" action="/api/auth/logout" class="inline">
              <button type="submit" class="hover:text-red-400 transition-colors text-mono-400">Log Out</button>
            </form>
          </div>
        ) : (
          <>
            <a href="/login" class="hover:text-mono-50 transition-colors">Sign In</a>
            <a href="/signup" class="bg-mono-800 text-mono-50 px-4 py-2 rounded-full hover:bg-mono-700 transition-colors font-bold">Sign Up</a>
          </>
        )}
      </nav>
    </div>
    
  </div>
</header>

<script is:inline>
  {
    // Script runs immediately to prevent flash of wrong theme
    const savedTheme = localStorage.getItem('theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    
    if (savedTheme === 'light' || (!savedTheme && !prefersDark)) {
      document.documentElement.setAttribute('data-theme', 'light');
    } else {
      document.documentElement.setAttribute('data-theme', 'dark');
    }

    function setupThemeToggle() {
      const toggleBtn = document.getElementById('theme-toggle');
      const darkIcon = document.querySelector('.dark-icon');
      const lightIcon = document.querySelector('.light-icon');
      
      if (!toggleBtn || !darkIcon || !lightIcon) return;

      function updateIcons() {
        if (document.documentElement.getAttribute('data-theme') === 'light') {
          darkIcon.classList.add('hidden');
          lightIcon.classList.remove('hidden');
        } else {
          lightIcon.classList.add('hidden');
          darkIcon.classList.remove('hidden');
        }
      }

      updateIcons();

      // Remove old listeners to prevent double-firing with Turbo
      const newBtn = toggleBtn.cloneNode(true);
      toggleBtn.parentNode.replaceChild(newBtn, toggleBtn);

      newBtn.addEventListener('click', () => {
        const currentTheme = document.documentElement.getAttribute('data-theme');
        const newTheme = currentTheme === 'light' ? 'dark' : 'light';
        
        document.documentElement.setAttribute('data-theme', newTheme);
        localStorage.setItem('theme', newTheme);
        updateIcons();
      });
    }

    document.addEventListener('turbo:load', setupThemeToggle);
    document.addEventListener('DOMContentLoaded', setupThemeToggle);
    setupThemeToggle(); // Run once immediately
  }
</script>
