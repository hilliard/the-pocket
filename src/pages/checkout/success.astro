---
import Header from '../../components/Header.astro';
import { query } from '../../server/db';
import { stripe } from '../../tools/stripe';
import '../../styles/global.css';

const sessionId = Astro.url.searchParams.get('session_id');

if (!sessionId) {
  return Astro.redirect('/');
}

// Fetch session from Stripe to determine mode
let session;
try {
  session = await stripe.checkout.sessions.retrieve(sessionId);
} catch (e) {
  return Astro.redirect('/');
}

const isSubscription = session.mode === 'subscription';

// ----------------------------------------------------
// SUBSCRIPTION LOGIC
// ----------------------------------------------------
let subIsReady = false;
if (isSubscription) {
  const subResult = await query(
    `SELECT id FROM subscriptions WHERE stripe_subscription_id = $1`,
    [session.subscription]
  );
  subIsReady = subResult.rows.length > 0;

  // DEVELOPMENT HACK / WEBHOOK FALLBACK
  if (!subIsReady && session.payment_status === 'paid') {
    try {
      const stripeSubscriptionId = session.subscription;
      const metadata = session.metadata || {};
      const buyerHumanId = metadata.buyer_human_id;
      const planId = metadata.subscription_plan;

      const subscriptionData = await stripe.subscriptions.retrieve(stripeSubscriptionId as string);
      const currentPeriodEnd = new Date(subscriptionData.current_period_end * 1000).toISOString();

      await query(
        `INSERT INTO subscriptions (customer_human_id, stripe_subscription_id, plan_id, status, current_period_end)
         VALUES ($1, $2, $3, $4, $5)
         ON CONFLICT (stripe_subscription_id) 
         DO UPDATE SET status = EXCLUDED.status, current_period_end = EXCLUDED.current_period_end`,
        [buyerHumanId, stripeSubscriptionId, planId, subscriptionData.status, currentPeriodEnd]
      );
      subIsReady = true;
    } catch (err) {
      console.error('Fallback subscription verification failed:', err);
    }
  }
}

// ----------------------------------------------------
// STANDARD ORDER LOGIC
// ----------------------------------------------------
let order;
let orderIsReady = false;

if (!isSubscription) {
  let orderResult = await query(
    `SELECT id, total_cents, customer_email, status, created_at 
     FROM orders 
     WHERE stripe_session_id = $1`,
    [sessionId]
  );
  order = orderResult.rows[0];

  // DEVELOPMENT HACK / WEBHOOK FALLBACK
  if (!order && session.payment_status === 'paid') {
    try {
      const customerEmail = session.customer_details?.email || session.customer_email || 'unknown@example.com';
      const totalCents = session.amount_total || 0;
      const metadata = session.metadata || {};
      
      const artistHumanId = metadata.artist_human_id;
      const buyerHumanId = metadata.buyer_human_id || null;
      const cartItemsStr = metadata.cart_items || '';

      const newOrder = await query(
        `INSERT INTO orders (artist_human_id, customer_human_id, stripe_session_id, customer_email, subtotal_cents, total_cents, status)
         VALUES ($1, $2, $3, $4, $5, $6, 'paid')
         ON CONFLICT (stripe_session_id) DO UPDATE SET status = 'paid'
         RETURNING id, total_cents, customer_email, status, created_at`,
        [artistHumanId, buyerHumanId, sessionId, customerEmail, totalCents, totalCents]
      );
      
      order = newOrder.rows[0];

      if (cartItemsStr) {
        const items = cartItemsStr.split(',');
        for (const item of items) {
          const [type, id, priceStr] = item.split(':');
          const price = parseInt(priceStr, 10);
          
          await query(
            `INSERT INTO order_items (order_id, entity_type, entity_id, price_cents)
             VALUES ($1, $2, $3, $4)`,
            [order.id, type, id, price]
          );
        }
      }
    } catch (err) {
      console.error('Fallback verification failed:', err);
    }
  }

  orderIsReady = !!order;
  if (orderIsReady) {
    Astro.cookies.delete('pocket_cart', { path: '/' });
  }
}

const isReady = isSubscription ? subIsReady : orderIsReady;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{isReady ? 'Confirmed!' : 'Verifying Payment...'}</title>
    <meta name="viewport" content="width=device-width" />
    {!isReady && <meta http-equiv="refresh" content="3" />}
  </head>
  <body class="bg-mono-950 text-mono-50 min-h-screen flex flex-col">
    <Header />
    
    <main class="flex-1 flex items-center justify-center p-6">
      <div class="bg-mono-900 border border-mono-800 p-8 md:p-12 rounded-3xl shadow-2xl max-w-lg w-full text-center">
        
        {!isReady ? (
          <div class="flex flex-col items-center">
            <div class="w-16 h-16 border-4 border-mono-700 border-t-accent rounded-full animate-spin mb-6"></div>
            <h1 class="text-3xl font-black mb-2">Verifying Payment...</h1>
            <p class="text-mono-400">Please wait while we confirm with Stripe.</p>
          </div>
        ) : isSubscription ? (
          <div class="flex flex-col items-center animate-in fade-in zoom-in duration-500">
            <div class="w-20 h-20 bg-accent/10 text-accent rounded-full flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
            </div>
            
            <h1 class="text-4xl font-black mb-2 text-white">Welcome to the Club!</h1>
            <p class="text-mono-400 mb-8">Your Fan Plan is now active. You have unlocked unlimited high-quality streaming across the entire platform.</p>
            
            <a href="/dashboard" class="w-full bg-accent text-mono-950 font-bold py-4 rounded-xl hover:brightness-110 transition-all text-center block">
              Go To Dashboard
            </a>
          </div>
        ) : (
          <div class="flex flex-col items-center animate-in fade-in zoom-in duration-500">
            <div class="w-20 h-20 bg-green-500/10 text-green-500 rounded-full flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            
            <h1 class="text-4xl font-black mb-2 text-white">Order Confirmed!</h1>
            <p class="text-mono-400 mb-8">A receipt has been sent to <span class="font-bold text-mono-50">{order.customer_email}</span>.</p>
            
            <div class="w-full bg-mono-950 border border-mono-800 rounded-xl p-6 text-left mb-8">
              <div class="flex justify-between items-center border-b border-mono-800 pb-4 mb-4">
                <span class="text-mono-400">Order ID</span>
                <span class="font-mono text-sm">{order.id.split('-')[0]}</span>
              </div>
              <div class="flex justify-between items-center border-b border-mono-800 pb-4 mb-4">
                <span class="text-mono-400">Date</span>
                <span class="text-sm">{new Date(order.created_at).toLocaleDateString()}</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="font-bold text-lg">Total Paid</span>
                <span class="font-black text-xl text-accent">${(order.total_cents / 100).toFixed(2)}</span>
              </div>
            </div>

            <a href="/library" class="w-full bg-accent text-mono-950 font-bold py-4 rounded-xl hover:brightness-110 transition-all text-center block">
              View My Library
            </a>
          </div>
        )}
      </div>
    </main>
  </body>
</html>
