---
import Header from '../../components/Header.astro';
import { query } from '../../server/db';
import '../../styles/global.css';

// Read session from Astro locals (injected by middleware)
// @ts-ignore
const session = Astro.locals.session;

// Ensure the user is an artist
if (!session?.roles?.includes('artist')) {
  return Astro.redirect('/login');
}

// Fetch artist details
const artistResult = await query(`
  SELECT a.human_id, a.slug, a.stage_name, a.accent_color_hex, a.google_refresh_token 
  FROM artists a 
  WHERE a.human_id = $1
`, [session.humanId]);

if (artistResult.rows.length === 0) {
  // Edge case: They have the role, but no artist profile was created yet.
  return new Response('Artist profile not found. Please contact support.', { status: 404 });
}

const artist = artistResult.rows[0];

// Fetch their current catalog stats
const statsResult = await query(`
  SELECT 
    (SELECT COUNT(*) FROM albums WHERE artist_human_id = $1) as total_albums,
    (SELECT COUNT(*) FROM songs WHERE artist_human_id = $1) as total_songs,
    (SELECT COUNT(*) FROM merch WHERE artist_human_id = $1) as total_merch
`, [artist.human_id]);
const stats = statsResult.rows[0];

// Fetch recent albums
const albumsResult = await query(`SELECT id, title, album_type, price_cents, created_at FROM albums WHERE artist_human_id = $1 ORDER BY created_at DESC LIMIT 5`, [artist.human_id]);
const albums = albumsResult.rows;

// Fetch recent songs
const songsResult = await query(`SELECT id, title, individual_price_cents as price_cents, created_at FROM songs WHERE artist_human_id = $1 ORDER BY created_at DESC LIMIT 5`, [artist.human_id]);
const songs = songsResult.rows;

// Fetch recent merch
const merchResult = await query(`SELECT id, title, price_cents, inventory_count FROM merch WHERE artist_human_id = $1 ORDER BY created_at DESC LIMIT 5`, [artist.human_id]);
const merch = merchResult.rows;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Artist Dashboard | {artist.stage_name}</title>
    <meta name="viewport" content="width=device-width" />
    <style is:inline define:vars={{ color: artist.accent_color_hex }}>
      :root { --color-accent-dynamic: var(--color); }
    </style>
    <script>
      import "@hotwired/turbo";
    </script>
  </head>
  <body class="bg-mono-950 text-mono-50 min-h-screen selection:bg-accent selection:text-mono-950">
    <Header />
    <turbo-frame id="artist-modal"></turbo-frame>

    <main class="max-w-6xl mx-auto px-6 py-12">
      
      <div class="flex items-center justify-between mb-12 border-b border-mono-800 pb-8">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent/10 border border-accent/30 text-xs font-bold text-accent mb-4">
            ARTIST PORTAL
          </div>
          <h1 class="text-4xl font-black">Studio: {artist.stage_name}</h1>
          <p class="text-mono-400 mt-2">Manage your catalog, set pricing, and review your empire.</p>
        </div>
        
        <div class="flex gap-4">
          <a href={`/clients/artists/${artist.slug}/public`} class="px-6 py-2 bg-mono-800 hover:bg-mono-700 rounded-full font-medium transition-colors border border-mono-700 text-sm flex items-center gap-2">
            View Storefront
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        </div>
      </div>

      <!-- Quick Stats -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="p-6 bg-mono-900 border border-mono-800 rounded-2xl flex flex-col gap-2">
          <span class="text-mono-400 text-sm font-bold uppercase tracking-wider">Albums Released</span>
          <span class="text-3xl font-black">{stats.total_albums}</span>
        </div>
        <div class="p-6 bg-mono-900 border border-mono-800 rounded-2xl flex flex-col gap-2">
          <span class="text-mono-400 text-sm font-bold uppercase tracking-wider">Tracks</span>
          <span class="text-3xl font-black">{stats.total_songs}</span>
        </div>
        <div class="p-6 bg-mono-900 border border-mono-800 rounded-2xl flex flex-col gap-2">
          <span class="text-mono-400 text-sm font-bold uppercase tracking-wider">Merch Variants</span>
          <span class="text-3xl font-black">{stats.total_merch}</span>
        </div>
      </div>

      <!-- Creator Studio: Post Update -->
      <section class="mb-16">
        <div class="bg-mono-900 border border-mono-800 rounded-3xl p-8 relative overflow-hidden">
          <!-- Subtle glow effect -->
          <div class="absolute -top-10 -right-10 w-40 h-40 bg-accent/10 rounded-full blur-3xl pointer-events-none"></div>
          
          <h2 class="text-2xl font-black mb-2 flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
            </svg>
            Creator Studio
          </h2>
          <p class="text-mono-400 mb-6">Post an update, announce a tour, or share news directly to your public Hub. No algorithms, straight to your fans.</p>
          
          <form action="/api/artist/post" method="POST" class="flex flex-col gap-4">
            <textarea 
              name="content" 
              rows="3" 
              placeholder="What's happening? (e.g., 'New merch dropping this Friday! 🎸')" 
              class="w-full bg-mono-950 border border-mono-700 rounded-xl p-4 text-white placeholder-mono-500 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent resize-none transition-all"
              required
            ></textarea>
            
            <div class="flex justify-between items-center">
              <div class="text-xs text-mono-500 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Updates appear instantly on your front page.
              </div>
              <button type="submit" class="bg-accent text-mono-950 font-black px-8 py-3 rounded-full hover:brightness-110 transition-all shadow-[0_0_15px_rgba(var(--color-accent-dynamic),0.3)] hover:scale-105 active:scale-95 cursor-pointer">
                Post Update
              </button>
            </div>
          </form>
        </div>
      </section>

      <!-- Integrations Row -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
        
        <!-- Tools Callout -->
        <div class="bg-mono-900 border border-mono-700 p-6 rounded-2xl flex flex-col justify-between gap-4 relative overflow-hidden group">
          <div class="absolute inset-0 bg-gradient-to-r from-accent/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
          
          <div class="relative z-10">
            <div class="inline-flex items-center gap-2 px-2 py-1 rounded bg-accent/10 border border-accent/20 text-[10px] font-bold text-accent mb-2 uppercase tracking-wider">
              Creator Toolkit
            </div>
            <h4 class="font-bold text-mono-50 text-xl">Prepare Your Previews</h4>
            <p class="text-sm text-mono-400 mt-1">
              Download our free desktop toolkit to instantly generate 30-second audio previews.
            </p>
          </div>
          <a href="/downloads/tools/GoldTending-Audio-Tools.zip" download="GoldTending-Audio-Tools.zip" class="relative z-10 bg-mono-800 hover:bg-mono-700 border border-mono-600 text-mono-50 font-bold px-6 py-3 rounded-xl transition-all flex items-center justify-center gap-2 text-sm mt-4 w-fit">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Download Toolkit
          </a>
        </div>

        <!-- Native Tour Dates Integration -->
        <div class="bg-mono-900 border border-mono-700 p-6 rounded-2xl flex flex-col gap-4 relative overflow-hidden group">
          <div class="absolute inset-0 bg-gradient-to-l from-green-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
          
          <div class="relative z-10">
            <div class="inline-flex items-center gap-2 px-2 py-1 rounded bg-green-500/10 border border-green-500/20 text-[10px] font-bold text-green-400 mb-2 uppercase tracking-wider">
              Tour & Events
            </div>
            <h4 class="font-bold text-mono-50 text-xl">Add Show</h4>
            <p class="text-sm text-mono-400 mt-1 mb-4">
              Announce a new gig, livestream, or release party. It will instantly appear on your Hub.
            </p>

            <form action="/api/artist/event" method="POST" class="flex flex-col gap-3">
              <input 
                type="text" 
                name="title" 
                placeholder="Event Title (e.g., Summer Headline Tour)" 
                class="w-full bg-mono-950 border border-mono-700 rounded-lg p-3 text-sm text-white placeholder-mono-500 focus:outline-none focus:border-accent"
                required
              />
              <div class="flex gap-3">
                <input 
                  type="date" 
                  name="event_date" 
                  class="w-full bg-mono-950 border border-mono-700 rounded-lg p-3 text-sm text-white focus:outline-none focus:border-accent"
                  required
                />
                <input 
                  type="text" 
                  name="venue" 
                  placeholder="Venue (e.g., The Roxy)" 
                  class="w-full bg-mono-950 border border-mono-700 rounded-lg p-3 text-sm text-white placeholder-mono-500 focus:outline-none focus:border-accent"
                  required
                />
              </div>
              <input 
                type="url" 
                name="ticket_url" 
                placeholder="Ticket URL (Optional)" 
                class="w-full bg-mono-950 border border-mono-700 rounded-lg p-3 text-sm text-white placeholder-mono-500 focus:outline-none focus:border-accent"
              />
              
              <button type="submit" class="bg-mono-800 hover:bg-mono-700 text-white font-bold py-3 rounded-lg border border-mono-600 transition-all flex items-center justify-center gap-2 text-sm mt-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                Publish Show to Hub
              </button>
            </form>
          </div>
        </div>
        
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        
        <!-- Music Catalog -->
        <section class="bg-mono-900 border border-mono-800 rounded-3xl overflow-hidden flex flex-col">
          <div class="p-6 border-b border-mono-800 flex justify-between items-center bg-mono-950/30">
            <h2 class="text-xl font-bold">Media Catalog</h2>
            <div class="relative group">
              <button class="bg-accent text-mono-950 text-sm font-bold px-4 py-2 rounded-lg hover:brightness-110 transition-colors flex items-center gap-2">
                + Add Media
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </button>
              
              <!-- Dropdown Menu -->
              <div class="absolute right-0 mt-2 w-48 bg-mono-900 border border-mono-700 rounded-xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-20 overflow-hidden">
                <a href="/artist/albums/new?type=album" data-turbo-frame="artist-modal" class="block px-4 py-3 text-sm font-bold hover:bg-mono-800 transition-colors border-b border-mono-800">
                  💿 Full Album
                </a>
                <a href="/artist/albums/new?type=ep" data-turbo-frame="artist-modal" class="block px-4 py-3 text-sm font-bold hover:bg-mono-800 transition-colors border-b border-mono-800">
                  📼 EP Release
                </a>
                <a href="/artist/songs/new" data-turbo-frame="artist-modal" class="block px-4 py-3 text-sm font-bold hover:bg-mono-800 transition-colors border-b border-mono-800">
                  🎵 Single / Track
                </a>
                <a href="/artist/merch/new" data-turbo-frame="artist-modal" class="block px-4 py-3 text-sm font-bold hover:bg-mono-800 transition-colors">
                  👕 Physical Merch
                </a>
              </div>
            </div>
          </div>
          
          <div class="p-6 flex-1 flex flex-col gap-6">
            
            {albums.length > 0 && (
              <div>
                <h3 class="text-xs font-bold text-mono-500 uppercase tracking-wider mb-3">Recent Albums</h3>
                <div class="flex flex-col gap-3">
                  {albums.map((album: any) => (
                    <div class="flex items-center justify-between p-4 bg-mono-950 rounded-xl border border-mono-800">
                      <div>
                        <div class="flex items-center gap-2">
                          <span class="text-[10px] bg-purple-500/10 text-purple-400 border border-purple-500/20 px-1.5 py-0.5 rounded font-bold uppercase">{album.album_type || 'ALBUM'}</span>
                          <h4 class="font-bold text-mono-100">{album.title}</h4>
                        </div>
                        <p class="text-xs text-mono-500 mt-1">Released: {new Date(album.created_at).toLocaleDateString()}</p>
                      </div>
                      <div class="text-right flex flex-col items-end gap-1">
                        <span class="block font-black text-accent">${(album.price_cents / 100).toFixed(2)}</span>
                        <div class="flex items-center gap-3 mt-1">
                          <form method="POST" action={`/api/artist/albums/${album.id}/delete`} onsubmit="confirmDelete(event, 'this album')">
                            <button type="submit" class="text-xs text-red-500 hover:text-red-400 underline cursor-pointer">Delete</button>
                          </form>
                          <a href={`/artist/products/album/${album.id}/edit`} data-turbo-frame="artist-modal" class="text-xs text-mono-400 hover:text-white underline">Edit</a>
                          <a href={`/artist/albums/${album.id}/tracks`} data-turbo-frame="artist-modal" class="text-xs text-mono-400 hover:text-white underline">Manage Tracks</a>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {songs.length > 0 && (
              <div>
                <h3 class="text-xs font-bold text-mono-500 uppercase tracking-wider mb-3">Recent Singles / Tracks</h3>
                <div class="flex flex-col gap-3">
                  {songs.map((song: any) => (
                    <div class="flex items-center justify-between p-4 bg-mono-950 rounded-xl border border-mono-800">
                      <div>
                        <div class="flex items-center gap-2">
                          <span class="text-[10px] bg-blue-500/10 text-blue-400 border border-blue-500/20 px-1.5 py-0.5 rounded font-bold uppercase">SONG</span>
                          <h4 class="font-bold text-mono-100">{song.title}</h4>
                        </div>
                        <p class="text-xs text-mono-500 mt-1">Added: {new Date(song.created_at).toLocaleDateString()}</p>
                      </div>
                      <div class="text-right flex flex-col items-end gap-1">
                        <span class="block font-black text-accent">${(song.price_cents / 100).toFixed(2)}</span>
                        <div class="flex items-center gap-3 mt-1">
                          <form method="POST" action={`/api/artist/songs/${song.id}/delete`} onsubmit="confirmDelete(event, 'this track')">
                            <button type="submit" class="text-xs text-red-500 hover:text-red-400 underline cursor-pointer">Delete</button>
                          </form>
                          <a href={`/artist/products/song/${song.id}/edit`} data-turbo-frame="artist-modal" class="text-xs text-mono-400 hover:text-white underline">Edit</a>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {(albums.length === 0 && songs.length === 0) && (
              <div class="flex flex-col items-center justify-center py-12 text-center border border-dashed border-mono-700 rounded-2xl h-full">
                <span class="text-4xl mb-4 opacity-50">🎵</span>
                <p class="text-mono-400 font-medium">Your discography is empty.</p>
                <p class="text-mono-500 text-sm mt-1">Upload your first album or single to start selling.</p>
              </div>
            )}
          </div>
        </section>

        <!-- Physical Merch -->
        <section class="bg-mono-900 border border-mono-800 rounded-3xl overflow-hidden flex flex-col">
          <div class="p-6 border-b border-mono-800 flex justify-between items-center bg-mono-950/30">
            <h2 class="text-xl font-bold">Physical Merch</h2>
            <a href="/artist/merch/new" data-turbo-frame="artist-modal" class="bg-accent text-mono-950 text-sm font-bold px-4 py-2 rounded-lg hover:brightness-110 transition-colors">
              + New Item
            </a>
          </div>
          
          <div class="p-6 flex-1">
            {merch.length === 0 ? (
              <div class="flex flex-col items-center justify-center py-12 text-center border border-dashed border-mono-700 rounded-2xl">
                <span class="text-4xl mb-4 opacity-50">👕</span>
                <p class="text-mono-400 font-medium">No merch listed.</p>
                <p class="text-mono-500 text-sm mt-1">Sell t-shirts, vinyl, or hats directly to fans.</p>
              </div>
            ) : (
              <div class="flex flex-col gap-3">
                {merch.map((item: any) => (
                  <div class="flex items-center justify-between p-4 bg-mono-950 rounded-xl border border-mono-800">
                    <div>
                      <h4 class="font-bold text-mono-100">{item.title}</h4>
                      <p class="text-xs text-mono-500">Stock: {item.inventory_count} remaining</p>
                    </div>
                    <div class="text-right">
                      <span class="block font-black text-accent">${(item.price_cents / 100).toFixed(2)}</span>
                      <a href={`/artist/products/merch/${item.id}/edit`} data-turbo-frame="artist-modal" class="text-xs text-mono-400 hover:text-white underline mt-1 block">Edit</a>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        </section>

      </div>
    </main>

    <!-- Custom Confirm Dialog -->
    <dialog id="deleteConfirmDialog" class="bg-transparent p-0 backdrop:bg-mono-950/80 backdrop:backdrop-blur-sm open:animate-in open:fade-in open:zoom-in-95 duration-200 m-auto">
      <div class="bg-mono-900 border border-mono-800 rounded-3xl w-full max-w-sm shadow-2xl p-6 text-center">
        <div class="w-16 h-16 bg-red-500/10 rounded-full flex items-center justify-center mx-auto mb-4 border border-red-500/20 text-red-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
        </div>
        <h3 class="text-xl font-black text-mono-50 mb-2">Are you sure?</h3>
        <p class="text-mono-400 text-sm mb-6">You are about to delete <span id="deleteItemName" class="font-bold text-mono-300">this item</span>. This action cannot be undone.</p>
        <div class="flex gap-3 justify-center">
          <button type="button" onclick="closeConfirmDialog()" class="px-6 py-3 bg-mono-800 text-white rounded-xl font-bold hover:bg-mono-700 transition-colors w-1/2">
            Cancel
          </button>
          <button type="button" id="confirmDeleteBtn" class="px-6 py-3 bg-red-500 text-white rounded-xl font-bold hover:bg-red-600 transition-colors w-1/2">
            Delete
          </button>
        </div>
      </div>
    </dialog>

    <script is:inline>
      {
        let pendingForm = null;
        const dialog = document.getElementById('deleteConfirmDialog');
        const itemNameSpan = document.getElementById('deleteItemName');
        const confirmBtn = document.getElementById('confirmDeleteBtn');

        window.confirmDelete = function(event, itemName) {
          event.preventDefault(); // Stop native submission
          pendingForm = event.target;
          itemNameSpan.textContent = itemName;
          dialog.showModal();
        };

        window.closeConfirmDialog = function() {
          dialog.close();
          pendingForm = null;
        };

        // Remove old listeners to prevent duplicates on Turbo reloads
        const newConfirmBtn = confirmBtn.cloneNode(true);
        confirmBtn.parentNode.replaceChild(newConfirmBtn, confirmBtn);

        newConfirmBtn.addEventListener('click', () => {
          if (pendingForm) {
            // Submit the form
            pendingForm.submit();
          }
        });
      }
    </script>
  </body>
</html>
