---
import '../../../styles/global.css';
import { verifySession } from '../../../server/auth';

const sessionCookie = Astro.cookies.get('pocket_session')?.value;
if (!sessionCookie) return Astro.redirect('/login');
const session = await verifySession(sessionCookie);
if (!session || !session.roles?.includes('artist')) {
  return new Response('Unauthorized', { status: 403 });
}

// Check if they want to create an album or an EP from the URL parameter
const type = Astro.url.searchParams.get('type') || 'album';
const typeDisplay = type === 'ep' ? 'EP Release' : 'Full Album';
---

<html lang="en">
  <head>
    <title>Create New {typeDisplay}</title>
    <meta name="turbo-cache-control" content="no-cache">
  </head>
  <body>
    <turbo-frame id="artist-modal">
      <div class="fixed inset-0 bg-mono-950/80 backdrop-blur-sm z-50 flex items-center justify-center p-6 animate-in fade-in duration-200">
        <div class="bg-mono-900 border border-mono-700 rounded-3xl p-8 max-w-lg w-full shadow-2xl relative max-h-[90vh] overflow-y-auto">
          
          <!-- Close Button -->
          <button type="button" onclick="const f=document.getElementById('artist-modal'); f.innerHTML=''; f.removeAttribute('src');" class="absolute top-6 right-6 text-mono-500 hover:text-white transition-colors cursor-pointer z-10">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>

          <div class="mb-8">
            <div class="inline-flex items-center gap-2 px-2 py-1 rounded bg-purple-500/20 text-purple-400 font-bold text-[10px] uppercase tracking-wider mb-2">
              Autonomous Upload
            </div>
            <h2 class="text-2xl font-black">Release a {typeDisplay}</h2>
            <p class="text-mono-400 text-sm mt-1">Create the core album details. You will upload the individual audio tracks on the next screen.</p>
          </div>

          <form method="POST" action="/api/artist/products/create-album" enctype="multipart/form-data" data-turbo="false" class="flex flex-col gap-5">
            <input type="hidden" name="album_type" value={type} />
            
            <div class="flex flex-col gap-2">
              <label class="text-xs font-bold uppercase tracking-wider text-mono-400">Album Title</label>
              <input type="text" name="title" class="w-full bg-mono-950 border border-mono-700 rounded-xl px-4 py-3 text-mono-50 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-all" required placeholder="e.g. Songs in the Key of Life" />
            </div>

            <div class="flex gap-4">
              <div class="flex flex-col gap-2 w-1/2">
                <label class="text-xs font-bold uppercase tracking-wider text-mono-400">Price (USD)</label>
                <input type="number" step="0.01" name="price" value={type === 'ep' ? "4.99" : "9.99"} class="w-full bg-mono-950 border border-mono-700 rounded-xl px-4 py-3 text-mono-50 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-all" required />
              </div>
              <div class="flex flex-col gap-2 w-1/2">
                <label class="text-xs font-bold uppercase tracking-wider text-mono-400">Genre</label>
                <input type="text" name="genre" class="w-full bg-mono-950 border border-mono-700 rounded-xl px-4 py-3 text-mono-50 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-all" placeholder="e.g. R&B" />
              </div>
            </div>

            <div class="flex flex-col gap-2 mt-2">
              <label class="text-xs font-bold uppercase tracking-wider text-mono-400">Album Cover Art (.jpg or .png)</label>
              <div class="border-2 border-dashed border-mono-700 rounded-xl p-6 text-center hover:bg-mono-950/50 transition-colors group relative cursor-pointer">
                <input type="file" name="cover_file" accept=".jpg,.jpeg,.png,image/jpeg,image/png" required class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" onchange="document.getElementById('fileNameDisplay').textContent = this.files[0]?.name || 'No file selected'" />
                <span class="text-4xl block mb-2 opacity-50 group-hover:opacity-100 transition-opacity">🖼️</span>
                <span class="text-sm font-bold text-accent group-hover:brightness-125 transition-all">Select High-Res Image</span>
                <span class="text-xs text-mono-500 block mt-1">Recommended: 2000x2000px</span>
                <div id="fileNameDisplay" class="mt-4 text-xs font-mono text-mono-300 truncate px-4">No file selected</div>
              </div>
            </div>

            <div class="flex gap-4 mt-6">
              <button type="button" onclick="const f=document.getElementById('artist-modal'); f.innerHTML=''; f.removeAttribute('src');" class="w-1/3 text-center bg-mono-800 hover:bg-mono-700 text-mono-50 font-bold py-4 rounded-xl transition-colors flex items-center justify-center cursor-pointer">
                Cancel
              </button>
              
              <button type="submit" onclick="this.innerHTML='<span class=\'animate-pulse\'>Creating...</span>'; this.classList.add('opacity-80', 'pointer-events-none');" class="w-2/3 bg-accent hover:brightness-110 text-mono-950 font-black py-4 rounded-xl transition-colors shadow-[0_0_15px_rgba(245,158,11,0.3)] cursor-pointer flex justify-center items-center">
                Create Album Shell
              </button>
            </div>

          </form>
        </div>
      </div>
    </turbo-frame>
  </body>
</html>
