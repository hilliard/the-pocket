---
import { query } from '../../../server/db';

// Read session from Astro locals
// @ts-ignore
const session = Astro.locals.session;

if (!session?.roles?.includes('artist')) {
  return Astro.redirect('/login');
}
---

<turbo-frame id="artist-modal">
  <div class="fixed inset-0 z-50 flex items-center justify-center bg-mono-950/80 backdrop-blur-sm p-4 animate-in fade-in duration-200">
    <div class="bg-mono-900 border border-mono-800 rounded-3xl w-full max-w-lg shadow-2xl relative overflow-hidden">
      
      <!-- Header -->
      <div class="bg-mono-950/50 p-6 border-b border-mono-800 flex justify-between items-center">
        <div>
          <h2 class="text-xl font-black">Upload New Song</h2>
          <p class="text-xs text-mono-400 mt-1">Add a track to your catalog</p>
        </div>
        <a href="/artist/dashboard" class="text-mono-400 hover:text-mono-50 bg-mono-800 hover:bg-mono-700 p-2 rounded-full transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>

      <!-- Form -->
      <form method="POST" action="/api/artist/songs/create" data-turbo-frame="_top" enctype="multipart/form-data" class="p-6 flex flex-col gap-5">
        
        <div class="flex flex-col gap-2">
          <label class="text-xs font-bold uppercase tracking-wider text-mono-400">Song Title</label>
          <input type="text" name="title" class="w-full bg-mono-950 border border-mono-700 rounded-xl px-4 py-3 focus:border-accent outline-none" required placeholder="e.g. Superstition" />
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="flex flex-col gap-2">
            <label class="text-xs font-bold uppercase tracking-wider text-mono-400">Master Audio File</label>
            <input type="file" name="masterAudio" accept="audio/*" class="w-full bg-mono-950 border border-mono-700 rounded-xl px-4 py-2 focus:border-accent outline-none text-sm text-mono-400 file:mr-4 file:py-1.5 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-bold file:bg-mono-800 file:text-mono-50 hover:file:bg-mono-700 transition-all cursor-pointer" required />
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-xs font-bold uppercase tracking-wider text-mono-400">30s Preview Clip (Optional)</label>
            <input type="file" name="previewAudio" accept="audio/*" class="w-full bg-mono-950 border border-mono-700 rounded-xl px-4 py-2 focus:border-accent outline-none text-sm text-mono-400 file:mr-4 file:py-1.5 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-bold file:bg-accent file:text-mono-950 hover:file:brightness-110 transition-all cursor-pointer" />
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="flex flex-col gap-2">
            <label class="text-xs font-bold uppercase tracking-wider text-mono-400">Price (Cents)</label>
            <input type="number" name="priceCents" class="w-full bg-mono-950 border border-mono-700 rounded-xl px-4 py-3 focus:border-accent outline-none font-mono" required placeholder="99" min="0" value="99" />
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-xs font-bold uppercase tracking-wider text-mono-400">Genre</label>
            <input type="text" name="genre" class="w-full bg-mono-950 border border-mono-700 rounded-xl px-4 py-3 focus:border-accent outline-none" placeholder="e.g. Funk" />
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="flex flex-col gap-2">
            <label class="text-xs font-bold uppercase tracking-wider text-mono-400">Duration (Sec)</label>
            <input type="number" name="duration" class="w-full bg-mono-950 border border-mono-700 rounded-xl px-4 py-3 focus:border-accent outline-none font-mono" placeholder="215" min="1" />
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-xs font-bold uppercase tracking-wider text-mono-400">BPM</label>
            <input type="number" name="bpm" class="w-full bg-mono-950 border border-mono-700 rounded-xl px-4 py-3 focus:border-accent outline-none font-mono" placeholder="120" min="1" />
          </div>
        </div>
        <div class="flex flex-col gap-2">
          <label class="text-xs font-bold uppercase tracking-wider text-mono-400">ISRC Code (Optional)</label>
          <input type="text" name="isrc" class="w-full bg-mono-950 border border-mono-700 rounded-xl px-4 py-3 focus:border-accent outline-none font-mono text-sm" placeholder="US-S1Z-99-00001" />
        </div>

        <div class="flex items-center gap-3 p-4 bg-mono-950 rounded-xl border border-mono-800">
          <input type="checkbox" id="isExplicit" name="isExplicit" value="true" class="w-5 h-5 accent-accent" />
          <label for="isExplicit" class="font-bold cursor-pointer text-sm">Contains Explicit Lyrics</label>
        </div>

        <div class="mt-4 flex justify-end gap-3">
          <a href="/artist/dashboard" class="px-6 py-3 rounded-xl font-bold text-mono-400 hover:text-white transition-colors">Cancel</a>
          <button type="submit" class="bg-accent text-mono-950 px-6 py-3 rounded-xl font-bold hover:brightness-110 transition-colors">
            Publish Song
          </button>
        </div>
      </form>
    </div>
  </div>
</turbo-frame>
