---
import Header from '../../../components/Header.astro';
import { query } from '../../../server/db';
import { verifySession } from '../../../server/auth';
import '../../../styles/global.css';

const { id } = Astro.params;

const sessionCookie = Astro.cookies.get('pocket_session')?.value;
if (!sessionCookie) return Astro.redirect('/login');

const session = await verifySession(sessionCookie);
if (!session) return Astro.redirect('/login');

// 1. Verify that they own this album OR they are the artist who uploaded it
const authCheck = await query(
  `SELECT o.id FROM orders o
   JOIN order_items oi ON o.id = oi.order_id
   WHERE (o.customer_human_id = $1 OR o.customer_email = 'grammyhaynes0727@gmail.com')
     AND oi.entity_type = 'album' 
     AND oi.entity_id = $2
     AND o.status = 'paid'
   UNION
   SELECT id FROM albums WHERE artist_human_id = $1 AND id = $2`,
  [session.humanId, id]
);

if (authCheck.rows.length === 0) {
  return Astro.redirect('/library?error=unauthorized_album');
}

// 2. Fetch Album Details
const albumRes = await query(`SELECT title, cover_url FROM albums WHERE id = $1`, [id]);
const album = albumRes.rows[0];

if (!album) {
  return Astro.redirect('/library');
}

// 3. Fetch the Songs inside the Album
const songsRes = await query(
  `SELECT s.id, s.title, s.master_audio_path, asg.track_number 
   FROM songs s
   JOIN album_songs asg ON asg.song_id = s.id
   WHERE asg.album_id = $1
   ORDER BY asg.track_number ASC`,
  [id]
);
const tracks = songsRes.rows;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{album.title} | The Pocket</title>
    <meta name="viewport" content="width=device-width" />
  </head>
  <body class="bg-mono-950 text-mono-50 min-h-screen">
    <Header />

    <main class="max-w-4xl mx-auto px-6 py-12">
      <a href="/library" class="text-mono-400 hover:text-white font-bold mb-8 inline-block transition-colors">
        &larr; Back to Library
      </a>

      <div class="flex flex-col md:flex-row gap-8 mb-12">
        <div class="w-full md:w-64 flex-shrink-0">
          <div class="aspect-square bg-mono-900 rounded-2xl overflow-hidden border border-mono-800 shadow-2xl">
            {album.cover_url ? (
              <img src={album.cover_url} alt={album.title} class="w-full h-full object-cover" />
            ) : (
              <div class="w-full h-full flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-mono-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
                </svg>
              </div>
            )}
          </div>
        </div>
        <div class="flex flex-col justify-end">
          <h2 class="text-accent font-bold tracking-widest uppercase mb-2">Album</h2>
          <h1 class="text-5xl font-black mb-4">{album.title}</h1>
          <p class="text-mono-400">{tracks.length} {tracks.length === 1 ? 'Track' : 'Tracks'} • High-Quality Masters</p>
        </div>
      </div>

      <div class="bg-mono-900 border border-mono-800 rounded-3xl overflow-hidden">
        <div class="hidden md:grid grid-cols-12 gap-4 p-4 border-b border-mono-800 text-mono-500 font-bold text-sm tracking-wider uppercase">
          <div class="col-span-1 text-center">#</div>
          <div class="col-span-6">Title</div>
          <div class="col-span-5 text-right">Actions</div>
        </div>

        <div class="flex flex-col divide-y divide-mono-800/50">
          {tracks.map(track => (
            <div class="grid grid-cols-1 md:grid-cols-12 gap-4 p-4 items-center hover:bg-mono-800/50 transition-colors group">
              <div class="col-span-1 text-mono-500 font-bold text-center hidden md:block">
                {track.track_number}
              </div>
              <div class="col-span-12 md:col-span-5">
                <div class="font-bold text-lg md:text-base mb-2 md:mb-0">
                  <span class="md:hidden text-mono-500 mr-2">{track.track_number}.</span>
                  {track.title}
                </div>
              </div>
              <div class="col-span-12 md:col-span-6 flex flex-col xl:flex-row items-center gap-4 justify-end">
                <audio 
                  src={`/api/media/stream?type=master&path=${encodeURIComponent(track.master_audio_path)}`} 
                  controls 
                  controlsList="nodownload"
                  class="w-full xl:w-64 h-10 rounded-md outline-none"
                ></audio>
                
                <a 
                  href={`/api/media/download?path=${encodeURIComponent(track.master_audio_path)}&title=${encodeURIComponent(track.title)}`}
                  target="_blank"
                  class="w-full xl:w-auto bg-mono-800 hover:bg-mono-700 text-white font-bold py-2 px-4 rounded-lg text-sm transition-colors border border-mono-700 flex items-center justify-center gap-2 whitespace-nowrap"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                  </svg>
                  Download
                </a>
              </div>
            </div>
          ))}

          {tracks.length === 0 && (
            <div class="p-8 text-center text-mono-500">
              This album does not have any tracks yet.
            </div>
          )}
        </div>
      </div>

    </main>
  </body>
</html>
