---
import { getAllArtists } from '../../../tools/getAllArtists';
import { query } from '../../../server/db';
import Header from '../../../components/Header.astro';
import '../../../styles/global.css';

// Fetch artists
const artistsResult = await query('SELECT slug, stage_name, bio, accent_color_hex FROM artists ORDER BY stage_name ASC');
const artists = artistsResult.rows;
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>The Pocket - Master Portal</title>
    <script src="../../../scripts/hotwire.ts"></script>
    
    <!-- We assign a neutral accent for the master portal -->
    <style is:inline>
      :root {
        --color-accent-dynamic: #a855f7; /* Purple */
      }
    </style>
  </head>
  <body class="bg-mono-950 text-mono-50 min-h-screen selection:bg-accent selection:text-mono-950">
    
    <Header />

    <main class="pt-28 pb-20 px-6 max-w-7xl mx-auto flex flex-col gap-24">
      
      <!-- Hero Section -->
      <section class="flex flex-col items-center text-center gap-8 py-12 md:py-24">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-mono-900 border border-mono-800 text-xs font-semibold text-accent mb-4">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
          </span>
          Master System Online
        </div>
        <h2 class="text-5xl md:text-7xl font-black tracking-tighter max-w-4xl leading-[1.1]">
          The premier infrastructure for <span class="text-accent">digital creators.</span>
        </h2>
        <p class="text-lg md:text-xl text-mono-400 max-w-2xl leading-relaxed">
          A fully unified ecosystem. Manage your storefront, dispatch newsletters, split complex expenses, and handle your global media catalog from a single deterministic platform.
        </p>
      </section>

      <!-- Services Grid -->
      <section id="services" class="scroll-mt-32">
        <div class="flex items-center gap-4 mb-8">
          <h3 class="text-2xl font-bold">Platform Services</h3>
          <div class="h-px bg-mono-800 flex-1"></div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <!-- Artists Module -->
          <div class="group p-6 rounded-2xl bg-mono-900 border border-mono-800 hover:border-accent/50 transition-colors cursor-pointer flex flex-col gap-4 relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-b from-accent/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="w-12 h-12 rounded-xl bg-mono-800 flex items-center justify-center text-accent">
               <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" /></svg>
            </div>
            <h4 class="text-lg font-bold">Artist Storefronts</h4>
            <p class="text-sm text-mono-400 leading-relaxed">Direct-to-consumer catalogs with unified Hotwire carts and dynamic accent styling.</p>
          </div>

          <!-- Me-Commerce Module -->
          <div class="group p-6 rounded-2xl bg-mono-900 border border-mono-800 hover:border-accent/50 transition-colors cursor-pointer flex flex-col gap-4 relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-b from-accent/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="w-12 h-12 rounded-xl bg-mono-800 flex items-center justify-center text-mono-300">
               <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
            </div>
            <h4 class="text-lg font-bold">Me-Commerce</h4>
            <p class="text-sm text-mono-400 leading-relaxed">Independent product sales with integrated Stripe billing and Resend receipt dispatch.</p>
          </div>

          <!-- Split Expense Module -->
          <div class="group p-6 rounded-2xl bg-mono-900 border border-mono-800 hover:border-accent/50 transition-colors cursor-pointer flex flex-col gap-4 relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-b from-accent/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="w-12 h-12 rounded-xl bg-mono-800 flex items-center justify-center text-mono-300">
               <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
            </div>
            <h4 class="text-lg font-bold">Split Expense</h4>
            <p class="text-sm text-mono-400 leading-relaxed">Complex tour and travel itinerary tracking with dynamic sequence sorting.</p>
          </div>

          <!-- Newsletter Module -->
          <div class="group p-6 rounded-2xl bg-mono-900 border border-mono-800 hover:border-accent/50 transition-colors cursor-pointer flex flex-col gap-4 relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-b from-accent/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="w-12 h-12 rounded-xl bg-mono-800 flex items-center justify-center text-mono-300">
               <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            </div>
            <h4 class="text-lg font-bold">Newsletter Hub</h4>
            <p class="text-sm text-mono-400 leading-relaxed">Automated audience engagement leveraging verified domain delivery pipelines.</p>
          </div>
        </div>
      </section>

      <!-- Featured Artists Directory -->
      <section id="artists" class="scroll-mt-32">
        <div class="flex items-center gap-4 mb-8">
          <h3 class="text-2xl font-bold">Featured Artists</h3>
          <div class="h-px bg-mono-800 flex-1"></div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {artists.length === 0 ? (
            <p class="text-mono-500 italic">No artists have been registered yet.</p>
          ) : (
            artists.map(artist => (
              <a href={`/clients/artists/${artist.slug}/public`} class="group block relative overflow-hidden rounded-2xl border border-mono-800 bg-mono-900 transition-all hover:scale-[1.02] hover:shadow-xl hover:border-mono-600">
                <div class="h-32 w-full opacity-20 group-hover:opacity-40 transition-opacity" style={`background-color: ${artist.accent_color_hex}`}></div>
                <div class="absolute inset-0 p-6 flex flex-col justify-end bg-gradient-to-t from-mono-950 via-mono-950/80 to-transparent">
                  <div class="flex items-center gap-3">
                    <div class="w-4 h-4 rounded-full shadow-[0_0_10px_rgba(0,0,0,0.5)]" style={`background-color: ${artist.accent_color_hex}`}></div>
                    <h4 class="text-xl font-bold text-mono-50">{artist.stage_name}</h4>
                  </div>
                  <p class="text-mono-400 text-sm mt-2 font-medium">View Storefront &rarr;</p>
                </div>
              </a>
            ))
          )}
        </div>
      </section>

    </main>
    
    <footer class="border-t border-mono-800 py-12 text-center text-mono-500 text-sm">
      <p>&copy; {new Date().getFullYear()} The Pocket. Engineered via BLAST Master System.</p>
    </footer>
  </body>
</html>
