---
import { getArtistBySlug } from '../../../../../../../tools/getArtistBySlug';
import { query } from '../../../../../../../server/db';
import Header from '../../../../../../../components/Header.astro';
import '../../../../../../../styles/global.css';

const { slug, songId } = Astro.params;

const artist = await getArtistBySlug(slug as string);
if (!artist) {
  return Astro.redirect('/clients/public');
}

// Validate UUID to prevent Postgres crashes
const uuidRegex = /^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i;
if (!uuidRegex.test(songId as string)) {
  return new Response(null, { status: 404 });
}

// Fetch Song Details
const songResult = await query(`
  SELECT id, title, individual_price_cents as price_cents, genre, preview_audio_url, created_at
  FROM songs 
  WHERE id = $1 AND artist_human_id = $2
`, [songId, artist.id]);

if (songResult.rows.length === 0) {
  return Astro.redirect(`/clients/artists/${slug}/me-commerce`);
}

const song = songResult.rows[0];

const artistName = artist.name;
const accentColor = artist.accent_color_hex || '#3b82f6';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{song.title} | Single | {artistName} Store</title>
    
    <style is:inline set:html={`
      :root {
        --color-accent-dynamic: ${accentColor};
      }
    `} />
    <script src="../../../../../../../scripts/hotwire.ts"></script>
  </head>
  <body class="bg-mono-950 text-mono-50 min-h-screen selection:bg-accent selection:text-mono-950">
    <Header artistSlug={slug as string} artistName={artistName} />

    <main class="max-w-5xl mx-auto px-6 py-12">
      <!-- Back Navigation -->
      <button onclick="history.back()" class="inline-flex items-center gap-2 text-mono-400 hover:text-white transition-colors mb-8 font-bold text-sm group cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Go Back
      </button>

      <div class="flex flex-col md:flex-row gap-16 items-center md:items-start">
        
        <!-- Vinyl Record Visual for Song -->
        <aside class="w-full md:w-5/12 flex justify-center items-center relative">
          <div class="relative w-full aspect-square bg-[#0a0a0a] rounded-full shadow-[0_20px_60px_rgba(0,0,0,0.8)] border-[8px] border-[#111] flex items-center justify-center group overflow-hidden hover:rotate-12 transition-transform duration-1000 ease-out">
            <!-- Grooves -->
            <div class="absolute inset-0 rounded-full border border-[#222] m-[5%]"></div>
            <div class="absolute inset-0 rounded-full border border-[#222] m-[10%]"></div>
            <div class="absolute inset-0 rounded-full border border-[#222] m-[15%]"></div>
            <div class="absolute inset-0 rounded-full border border-[#222] m-[20%]"></div>
            <div class="absolute inset-0 rounded-full border border-[#222] m-[25%]"></div>
            <div class="absolute inset-0 rounded-full border border-[#222] m-[30%]"></div>
            
            <!-- Shine/Glare -->
            <div class="absolute inset-0 bg-gradient-to-tr from-white/10 via-transparent to-transparent rounded-full pointer-events-none transform -rotate-45"></div>
            <div class="absolute inset-0 bg-gradient-to-bl from-white/5 via-transparent to-transparent rounded-full pointer-events-none transform -rotate-45"></div>
            
            <!-- Label -->
            <div class="w-1/3 h-1/3 rounded-full flex flex-col items-center justify-center text-center shadow-inner z-10 p-2 relative" style={`background-color: ${accentColor}`}>
              <div class="w-3 h-3 bg-[#111] rounded-full absolute shadow-inner"></div>
              <span class="text-mono-950 font-black text-[9px] sm:text-[11px] leading-tight uppercase tracking-wider mt-8 line-clamp-2 px-1 mix-blend-multiply opacity-80">{song.title}</span>
            </div>
          </div>
        </aside>

        <!-- Song Details -->
        <section class="w-full md:w-7/12 flex flex-col gap-6">
          <div>
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-[10px] font-bold text-blue-400 mb-4 uppercase tracking-widest">
              Digital Single
            </div>
            <h1 class="text-5xl md:text-6xl font-black mb-3 tracking-tight">{song.title}</h1>
            <a href={`/clients/artists/${slug}/public`} class="text-2xl text-mono-400 hover:text-white transition-colors">{artistName}</a>
          </div>

          <div class="flex items-center gap-3">
            {song.genre && (
              <span class="text-xs text-mono-300 border border-mono-700 bg-mono-900 px-3 py-1.5 rounded-lg font-bold uppercase tracking-widest">{song.genre}</span>
            )}
            <span class="text-xs text-mono-500 border border-mono-800 bg-transparent px-3 py-1.5 rounded-lg font-bold uppercase tracking-widest">Released {new Date(song.created_at).getFullYear()}</span>
          </div>

          <div class="p-8 bg-mono-900 border border-mono-800 rounded-3xl mt-4 relative overflow-hidden group">
            <div class="absolute inset-0 bg-gradient-to-br from-white/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
            
            <div class="flex items-center justify-between mb-8 relative z-10">
              <span class="text-5xl font-black text-accent">${(song.price_cents / 100).toFixed(2)}</span>
            </div>

            <turbo-frame id={`cart_frame_song_${song.id}`} class="relative z-10">
              <form method="POST" action={`/api/cart/add`}>
                <input type="hidden" name="itemId" value={song.id} />
                <input type="hidden" name="itemType" value="song" />
                <button type="submit" class="w-full bg-accent hover:brightness-110 text-mono-950 font-black py-5 rounded-2xl transition-all shadow-[0_0_30px_rgba(var(--color-accent-dynamic),0.3)] flex items-center justify-center gap-3 hover:scale-[1.02] active:scale-[0.98] text-lg">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                  </svg>
                  Add Track to Cart
                </button>
              </form>
            </turbo-frame>
          </div>

          {song.preview_audio_url ? (
            <div class="mt-4 p-6 bg-mono-950 rounded-3xl border border-mono-800">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
                <h4 class="text-xs font-bold text-mono-400 uppercase tracking-widest">30-Second Preview</h4>
              </div>
              <audio controls controlslist="nodownload" class="w-full h-12 rounded-full bg-mono-900 border border-mono-700 shadow-inner">
                <source src={song.preview_audio_url} type="audio/mpeg" />
                Your browser does not support the audio element.
              </audio>
            </div>
          ) : (
            <div class="mt-4 p-6 bg-mono-950 rounded-3xl border border-mono-800 flex items-center justify-center">
              <span class="text-mono-500 text-sm font-medium">No preview available</span>
            </div>
          )}

        </section>
      </div>
    </main>
  </body>
</html>
