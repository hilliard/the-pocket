---
import { getArtistBySlug } from '../../../../../../../tools/getArtistBySlug';
import { getAlbumWithSongs } from '../../../../../../../tools/getAlbumWithSongs';
import Header from '../../../../../../../components/Header.astro';
import '../../../../../../../styles/global.css';

const { slug, albumId } = Astro.params;

const artist = await getArtistBySlug(slug as string);
if (!artist) {
  return Astro.redirect('/clients/public');
}

const album = await getAlbumWithSongs(albumId as string);
if (!album) {
  return Astro.redirect(`/clients/artists/${slug}/me-commerce`);
}

const artistName = artist.name;
const accentColor = artist.accent_color_hex || '#3b82f6';

function formatDuration(seconds: number) {
  const m = Math.floor(seconds / 60);
  const s = seconds % 60;
  return `${m}:${s.toString().padStart(2, '0')}`;
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{album.title} | {artistName} Store</title>
    
    <style is:inline set:html={`
      :root {
        --color-accent-dynamic: ${accentColor};
      }
    `} />
    <script src="../../../../../../../scripts/hotwire.ts"></script>
  </head>
  <body class="bg-mono-950 text-mono-50 min-h-screen">
    <Header artistSlug={slug as string} artistName={artistName} />

    <main class="max-w-4xl mx-auto px-6 py-12">
      <!-- Back Navigation -->
      <button onclick="history.back()" class="inline-flex items-center gap-2 text-mono-400 hover:text-white transition-colors mb-8 font-bold text-sm group cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Go Back
      </button>

      <div class="flex flex-col md:flex-row gap-12">
      <!-- Album Art & Meta -->
      <aside class="w-full md:w-1/3 flex flex-col gap-6">
        <div class="aspect-square w-full rounded-2xl overflow-hidden shadow-2xl border border-mono-800 bg-mono-900">
          {album.cover_url ? (
            <img src={album.cover_url} alt={album.title} class="w-full h-full object-cover" />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-mono-700">No Cover</div>
          )}
        </div>
        <div>
          <h1 class="text-3xl font-black">{album.title}</h1>
          <p class="text-xl text-mono-400">{artistName}</p>
          <div class="mt-4 flex items-center justify-between">
            <span class="text-2xl font-bold text-accent">${(album.price_cents / 100).toFixed(2)}</span>
            
            <turbo-frame id={`cart_frame_album_${album.id}`}>
              <form method="POST" action={`/api/cart/add`}>
                <input type="hidden" name="itemId" value={album.id} />
                <input type="hidden" name="itemType" value="album" />
                <button type="submit" class="bg-mono-50 hover:bg-mono-200 text-mono-950 px-4 py-2 rounded-full font-bold transition-all flex items-center gap-2">
                  Buy Album
                </button>
              </form>
            </turbo-frame>
          </div>
        </div>
      </aside>

      <!-- Tracklist -->
      <section class="w-full md:w-2/3 flex flex-col gap-4">
        <h2 class="text-xl font-bold border-b border-mono-800 pb-2 mb-4">Tracklist</h2>
        
        {album.songs.length === 0 ? (
          <p class="text-mono-500 italic">No tracks available yet.</p>
        ) : (
          <div class="flex flex-col gap-2">
            {album.songs.map((song) => (
              <div class="flex items-center justify-between p-4 rounded-xl hover:bg-mono-900 border border-transparent hover:border-mono-800 transition-colors group">
                <div class="flex items-center gap-4 flex-1">
                  <span class="text-mono-500 font-mono text-sm w-4 text-right">{song.track_number}</span>
                  <div class="flex-1">
                    <h4 class="font-bold text-mono-100 group-hover:text-accent transition-colors">{song.title}</h4>
                    <span class="text-xs text-mono-500 font-mono block mb-2">{formatDuration(song.duration_seconds)}</span>
                    {song.media_url && (
                      <audio controls class="h-8 w-full max-w-xs opacity-70 hover:opacity-100 transition-opacity">
                        <source src={song.media_url} type="audio/mpeg" />
                        Your browser does not support the audio element.
                      </audio>
                    )}
                  </div>
                </div>
                
                <div class="flex items-center gap-4">
                  <span class="text-sm font-bold text-mono-300">${(song.individual_price_cents / 100).toFixed(2)}</span>
                  
                  <turbo-frame id={`cart_frame_song_${song.id}`}>
                    <form method="POST" action={`/api/cart/add`}>
                      <input type="hidden" name="itemId" value={song.id} />
                      <input type="hidden" name="itemType" value="song" />
                      <button type="submit" class="text-mono-400 hover:text-accent p-2 rounded-full hover:bg-accent/10 transition-colors" aria-label="Buy Song">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                          <path d="M3 1a1 1 0 000 2h1.22l.305 1.222a.997.997 0 00.01.042l1.358 5.43-.893.892C3.74 11.846 4.632 14 6.414 14H15a1 1 0 000-2H6.414l1-1H14a1 1 0 00.894-.553l3-6A1 1 0 0017 3H6.28l-.31-1.243A1 1 0 005 1H3zM16 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM6.5 18a1.5 1.5 0 100-3 1.5 1.5 0 000 3z" />
                        </svg>
                      </button>
                    </form>
                  </turbo-frame>
                </div>
              </div>
            ))}
          </div>
        )}
      </section>
      </div>
    </main>
  </body>
</html>
