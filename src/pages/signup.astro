---
import Header from '../components/Header.astro';
import '../styles/global.css';

// Read error from URL if redirected back
const error = Astro.url.searchParams.get('error');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Sign Up | The Pocket</title>
  </head>
  <body class="bg-mono-950 text-mono-50 min-h-screen flex flex-col selection:bg-accent selection:text-mono-950">
    
    <Header />

    <main class="flex-1 flex flex-col items-center justify-center p-6">
      
      <div class="w-full max-w-md bg-mono-900 border border-mono-800 p-8 rounded-3xl shadow-2xl relative overflow-hidden">
        
        <!-- Decorative Glow -->
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-accent/20 rounded-full blur-[60px] pointer-events-none"></div>

        <div class="mb-8 text-center relative z-10">
          <h1 class="text-3xl font-black mb-2">Join The Pocket</h1>
          <p class="text-mono-400">Create an account to buy music or start your own store.</p>
        </div>

        {error && (
          <div class="mb-6 p-4 bg-red-500/10 border border-red-500/30 rounded-xl text-red-400 text-sm font-bold text-center">
            {error}
          </div>
        )}

        <form action="/api/auth/signup" method="POST" class="flex flex-col gap-5 relative z-10">
          
          <div class="grid grid-cols-2 gap-4">
            <div class="flex flex-col gap-2">
              <label for="firstName" class="text-xs font-bold uppercase tracking-wider text-mono-400 ml-1">First Name</label>
              <input type="text" id="firstName" name="firstName" required
                class="w-full bg-mono-950 border border-mono-700 rounded-xl px-4 py-3 text-mono-50 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-all"
                placeholder="Joe"
              />
            </div>
            <div class="flex flex-col gap-2">
              <label for="lastName" class="text-xs font-bold uppercase tracking-wider text-mono-400 ml-1">Last Name</label>
              <input type="text" id="lastName" name="lastName" required
                class="w-full bg-mono-950 border border-mono-700 rounded-xl px-4 py-3 text-mono-50 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-all"
                placeholder="User"
              />
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <label for="email" class="text-xs font-bold uppercase tracking-wider text-mono-400 ml-1">Email Address</label>
            <input type="email" id="email" name="email" required
              class="w-full bg-mono-950 border border-mono-700 rounded-xl px-4 py-3 text-mono-50 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-all"
              placeholder="joe@example.com"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label for="username" class="text-xs font-bold uppercase tracking-wider text-mono-400 ml-1">Username</label>
            <input type="text" id="username" name="username" required
              class="w-full bg-mono-950 border border-mono-700 rounded-xl px-4 py-3 text-mono-50 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-all"
              placeholder="joe_user_99"
            />
          </div>

          <div class="flex flex-col gap-2 relative">
            <label for="password" class="text-xs font-bold uppercase tracking-wider text-mono-400 ml-1">Password</label>
            <div class="relative w-full">
              <input type="password" id="password" name="password" required
                class="w-full bg-mono-950 border border-mono-700 rounded-xl px-4 py-3 pr-12 text-mono-50 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-all"
                placeholder="••••••••"
              />
              <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-mono-500 hover:text-white transition-colors password-toggle" aria-label="Toggle password visibility">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 eye-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 eye-off-icon hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.542 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                </svg>
              </button>
            </div>
          </div>

          <button type="submit" class="mt-2 w-full bg-accent text-mono-950 font-black py-4 rounded-xl hover:brightness-110 transition-all shadow-[0_0_20px_rgba(168,85,247,0.3)]">
            Create Account
          </button>

        </form>

        <p class="text-center text-mono-400 text-sm mt-8 relative z-10">
          Already have an account? 
          <a href="/login" class="text-accent font-bold hover:text-white transition-colors">Sign In</a>
        </p>

      </div>
    </main>
    <script>
      document.querySelectorAll('.password-toggle').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          const container = btn.closest('.relative');
          const input = container.querySelector('input');
          const eye = btn.querySelector('.eye-icon');
          const eyeOff = btn.querySelector('.eye-off-icon');
          
          if (input.type === 'password') {
            input.type = 'text';
            eye.classList.add('hidden');
            eyeOff.classList.remove('hidden');
          } else {
            input.type = 'password';
            eye.classList.remove('hidden');
            eyeOff.classList.add('hidden');
          }
        });
      });
    </script>
  </body>
</html>
